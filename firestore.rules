rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // =========================================================
    // HELPER FUNCTIONS
    // =========================================================

    function isSignedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function userExists() {
      return isSignedIn() &&
             exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function getUserData() {
      return userDoc().data;
    }

    function hasRole(role) {
      return userExists() &&
             getUserData().role == role;
    }

    // =========================================================
    // ADMIN CHECKS
    // =========================================================

    function isAdmin() {
      return isSignedIn() && (

        // users/{uid}.role
        (userExists() &&
         getUserData().role in ['admin', 'superadmin']) ||

        // users/{uid}.permissions.role
        (userExists() &&
         getUserData().permissions.role in ['admin', 'superadmin']) ||

        // admins collection
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||

        // custom claims
        request.auth.token.role in ['admin', 'superadmin']
      );
    }

    function isSuperAdmin() {
      return isSignedIn() && (

        // users/{uid}.role
        (userExists() &&
         getUserData().role == 'superadmin') ||

        // admins collection role
        (
          exists(/databases/$(database)/documents/admins/$(request.auth.uid)) &&
          get(/databases/$(database)/documents/admins/$(request.auth.uid))
            .data.role == 'superadmin'
        ) ||

        // custom claim
        request.auth.token.role == 'superadmin'
      );
    }

    // =========================================================
    // USERS
    // =========================================================

    match /users/{userId} {

      // Own profile OR admin
      allow get: if isSignedIn() &&
                  (request.auth.uid == userId || isAdmin());

      // Admin can list all users
      allow list: if isAdmin();

      // User creates own account only
      allow create: if isSignedIn() &&
                    request.auth.uid == userId &&
                    request.resource.data.role in ['student', 'hoster'];

      // User updates own non-sensitive fields
      allow update: if (
                        isSignedIn() &&
                        request.auth.uid == userId &&
                        !request.resource.data
                          .diff(resource.data)
                          .affectedKeys()
                          .hasAny([
                            'role',
                            'permissions',
                            'is_active'
                          ])
                      ) || isAdmin();

      // Only super admin deletes
      allow delete: if isSuperAdmin();

      // -----------------------------------------------------
      // PRIVACY SETTINGS
      // -----------------------------------------------------

      match /privacy_settings/{settingId} {
        allow read, write: if request.auth.uid == userId ||
                           isAdmin();
      }
    }

    // =========================================================
    // PROPERTIES
    // =========================================================

    match /properties/{propertyId} {

      allow read: if true;

      allow create, update, delete: if (
        isSignedIn() &&
        (
          isAdmin() ||

          (
            hasRole('hoster') &&
            request.resource.data.hoster_id == request.auth.uid
          )
        )
      );
    }

    // =========================================================
    // ROOMS
    // =========================================================

    match /rooms/{roomId} {

      allow read: if true;

      allow write: if isAdmin() ||
                    hasRole('hoster');
    }

    // =========================================================
    // BEDS
    // =========================================================

    match /beds/{bedId} {

      allow read: if true;

      allow write: if isAdmin() ||
                    hasRole('hoster');
    }

    // =========================================================
    // BOOKINGS
    // =========================================================

    match /bookings/{bookingId} {

      allow read: if isSignedIn() && (

        // Booking owner
        request.auth.uid == resource.data.user_id ||

        // Property owner
        request.auth.uid ==
        get(
          /databases/$(database)/documents/properties/$(resource.data.property_id)
        ).data.hoster_id ||

        // Admin
        isAdmin()
      );

      allow create: if isSignedIn() &&
                    request.resource.data.user_id ==
                    request.auth.uid;

      allow update: if isAdmin();

      allow delete: if isSuperAdmin();
    }

    // =========================================================
    // SUGGESTIONS
    // =========================================================

    match /suggestions/{suggestionId} {

      // Create own suggestion
      allow create: if isSignedIn() &&
                    request.resource.data.user_id ==
                    request.auth.uid;

      // Read own suggestions OR admin
      allow get, list: if isAdmin() ||
                       (
                         isSignedIn() &&
                         resource.data.user_id ==
                         request.auth.uid
                       );

      // Update own pending suggestion OR admin
      allow update: if isAdmin() ||
                    (
                      isSignedIn() &&
                      resource.data.user_id ==
                      request.auth.uid &&
                      resource.data.status == 'pending'
                    );

      // Delete admin only
      allow delete: if isAdmin();
    }

    // =========================================================
    // PROPERTY SUGGESTIONS
    // =========================================================

    match /property_suggestions/{suggestionId} {

      allow create: if isSignedIn() &&
                    request.resource.data.suggester_id ==
                    request.auth.uid;

      allow read: if isAdmin() ||
                  (
                    isSignedIn() &&
                    resource.data.suggester_id ==
                    request.auth.uid
                  );

      allow update, delete: if isAdmin();
    }

    // =========================================================
    // REPORTS
    // =========================================================

    match /reports/{reportId} {

      allow create: if isSignedIn() &&
                    request.resource.data.user_id ==
                    request.auth.uid;

      allow read: if isAdmin() ||
                  (
                    isSignedIn() &&
                    resource.data.user_id ==
                    request.auth.uid
                  );

      allow update, delete: if isAdmin();
    }

    // =========================================================
    // PAYMENTS
    // =========================================================

    match /payments/{paymentId} {

      allow read: if isSignedIn() && (
        request.auth.uid == resource.data.user_id ||
        isAdmin()
      );

      allow write: if false;
    }

    // =========================================================
    // INVOICES
    // =========================================================

    match /invoices/{invoiceId} {

      allow read: if isSignedIn() && (

        request.auth.uid ==
        get(
          /databases/$(database)/documents/bookings/$(resource.data.booking_id)
        ).data.user_id ||

        isAdmin()
      );

      allow write: if false;
    }

    // =========================================================
    // REVIEWS
    // =========================================================

    match /reviews/{reviewId} {

      allow read: if true;

      allow create: if isSignedIn();

      allow update, delete: if (
        isSignedIn() &&
        request.auth.uid == resource.data.user_id
      ) || isAdmin();
    }

    // =========================================================
    // WISHLISTS
    // =========================================================

    match /wishlists/{wishId} {

      allow read, write: if isSignedIn() &&
                         (
                           request.auth.uid ==
                           (
                             resource == null
                             ? request.resource.data.user_id
                             : resource.data.user_id
                           )
                         );
    }

    // =========================================================
    // NOTIFICATIONS
    // =========================================================

    match /notifications/{notifId} {

      allow read: if isSignedIn() &&
                  request.auth.uid ==
                  resource.data.user_id;

      allow update: if isSignedIn() &&
                    request.auth.uid ==
                    resource.data.user_id &&
                    request.resource.data
                      .diff(resource.data)
                      .affectedKeys()
                      .hasOnly(['is_read']);

      allow create, delete: if isAdmin();
    }

    // =========================================================
    // ANALYTICS
    // =========================================================

    match /analytics/{docId} {

      allow read: if isAdmin() ||
                  hasRole('hoster');

      allow write: if false;
    }

    // =========================================================
    // AUDIT LOGS
    // =========================================================

    match /audit_logs/{logId} {

      allow read, create: if isAdmin();

      allow update, delete: if false;
    }

    // =========================================================
    // ACTIVITY LOGS
    // =========================================================

    match /activity_logs/{logId} {

      allow read: if isAdmin();

      allow write: if false;
    }

    // =========================================================
    // CITIES
    // =========================================================

    match /cities/{cityId} {

      allow read: if true;

      allow write: if isAdmin();

      match /areas/{areaId} {

        allow read: if true;

        allow write: if isAdmin();
      }
    }

    // =========================================================
    // LOCATIONS
    // =========================================================

    match /locations/{locationId} {

      allow read: if true;

      allow write: if isAdmin();
    }

    // =========================================================
    // CONFIG
    // =========================================================

    match /config/{docId} {

      allow read: if true;

      allow write: if isAdmin();
    }

    // =========================================================
    // SETTINGS
    // =========================================================

    match /settings/global {

      allow read: if true;

      allow write: if isAdmin();
    }

    // =========================================================
    // HOSTER REQUESTS
    // =========================================================

    match /hoster_requests/{userId} {

      allow read: if isSignedIn() &&
                  (
                    request.auth.uid == userId ||
                    isAdmin()
                  );

      allow create: if isSignedIn() &&
                    request.auth.uid == userId;

      allow update: if isAdmin();
    }

    // =========================================================
    // ADMINS
    // =========================================================

    match /admins/{adminId} {

      allow read: if isAdmin();

      allow write: if isSuperAdmin();
    }
  }
}
