rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // =========================================================
    // HELPER FUNCTIONS
    // =========================================================

    function isSignedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function userExists() {
      return isSignedIn() &&
             exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function getUserData() {
      return userDoc().data;
    }

    function hasRole(role) {
      return userExists() &&
             'role' in getUserData() &&
             getUserData().role == role;
    }

    function isHoster() {
      return userExists() &&
             'role' in getUserData() &&
             getUserData().role in ['hoster', 'owner', 'manager', 'agency'];
    }

    // =========================================================
    // ADMIN CHECKS
    // =========================================================

    function isAdmin() {
      return isSignedIn() && (
        // users/{uid}.role
        (userExists() && 'role' in getUserData() && getUserData().role in ['admin', 'superadmin']) ||
        // users/{uid}.permissions.role
        (userExists() && 'permissions' in getUserData() && getUserData().permissions != null && 'role' in getUserData().permissions && getUserData().permissions.role in ['admin', 'superadmin']) ||
        // admins collection
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        // custom claims
        ('role' in request.auth.token && request.auth.token.role in ['admin', 'superadmin'])
      );
    }

    function isSuperAdmin() {
      return isSignedIn() && (
        // users/{uid}.role
        (userExists() && 'role' in getUserData() && getUserData().role == 'superadmin') ||
        // admins collection role
        (
          exists(/databases/$(database)/documents/admins/$(request.auth.uid)) &&
          'role' in get(/databases/$(database)/documents/admins/$(request.auth.uid)).data &&
          get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.role == 'superadmin'
        ) ||
        // custom claim
        ('role' in request.auth.token && request.auth.token.role == 'superadmin')
      );
    }

    // =========================================================
    // USERS
    // =========================================================

    match /users/{userId} {
      // Allow anyone to check status/profile by ID (prevent permission errors in properties list/details)
      allow get: if true;

      // Admin can list all users
      allow list: if isAdmin();

      // User creates own account with initial roles
      allow create: if isSignedIn() &&
                    request.auth.uid == userId &&
                    (
                      !('role' in request.resource.data) ||
                      request.resource.data.role in ['student', 'hoster', 'professional', 'owner', 'manager', 'agency']
                    );

      // User updates own profile
      allow update: if (
        isSignedIn() &&
        request.auth.uid == userId &&
        // Prevent users from changing system-level flags
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['permissions', 'is_active']) &&
        // Secure verification flow: users can submit but not verify themselves
        (
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(['verification']) ||
          !request.resource.data.verification.diff(resource.data.get('verification', {})).affectedKeys().hasAny([
            'roleIdVerified', 'govIdVerified', 'addressVerified', 'panVerified',
            'businessProofVerified', 'propertyProofVerified', 'selfieVerified'
          ])
        ) &&
        // If role is changed, it must be to an allowed public role
        (
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role']) ||
          request.resource.data.role in ['student', 'hoster', 'professional', 'owner', 'manager', 'agency']
        )
      ) || isAdmin();

      // Only super admin deletes
      allow delete: if isSuperAdmin();

      // Sub-collections (Privacy, etc)
      match /{allSubcollections=**} {
        allow read, write: if request.auth.uid == userId || isAdmin();
      }
    }

    // =========================================================
    // PROPERTIES
    // =========================================================

    function userIsHosterOf(propertyId) {
      return get(/databases/$(database)/documents/properties/$(propertyId)).data.hoster_id == request.auth.uid ||
             get(/databases/$(database)/documents/properties/$(propertyId)).data.hosterId == request.auth.uid;
    }

    match /properties/{propertyId} {
      allow read: if true;

      allow create: if isSignedIn() && (
        isAdmin() ||
        (isHoster() && (request.resource.data.hoster_id == request.auth.uid || request.resource.data.hosterId == request.auth.uid))
      );

      allow update, delete: if isSignedIn() && (
        isAdmin() ||
        (isHoster() &&
          (resource.data.hoster_id == request.auth.uid || resource.data.hosterId == request.auth.uid) &&
          (request.resource.data.hoster_id == request.auth.uid || request.resource.data.hosterId == request.auth.uid)
        )
      );

      // Private Data Vault (Document-Level Security)
      match /private/details {
        allow read: if isSignedIn() && (
          isAdmin() ||
          userIsHosterOf(propertyId) ||
          exists(/databases/$(database)/documents/unlocked_data/$(request.auth.uid + "_" + propertyId))
        );
        allow write: if isAdmin() || userIsHosterOf(propertyId);
      }

      // Floors, Rooms and Beds sub-resources
      match /floors/{floorId} {
        allow read: if true;
        allow write: if isAdmin() || userIsHosterOf(propertyId);
      }
      match /rooms/{roomId} {
        allow read: if true;
        allow write: if isAdmin() || userIsHosterOf(propertyId);

        match /beds/{bedId} {
          allow read: if true;
          allow write: if isAdmin() || userIsHosterOf(propertyId);
        }
      }
      match /beds/{bedId} {
        allow read: if true;
        allow write: if isAdmin() || userIsHosterOf(propertyId);
      }
    }

    // =========================================================
    // REDESIGN TOP-LEVEL COLLECTIONS (V2)
    // =========================================================

    match /rooms/{roomId} {
      allow read: if true;
      allow create: if isAdmin() || (isSignedIn() && userIsHosterOf(request.resource.data.propertyId));
      allow update: if isAdmin() || (
        isSignedIn() &&
        userIsHosterOf(resource.data.propertyId) &&
        // Prevent moving room to another property
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['propertyId'])
      );
      allow delete: if isAdmin() || (isSignedIn() && userIsHosterOf(resource.data.propertyId));
    }

    match /beds/{bedId} {
      allow read: if true;
      allow create: if isAdmin() || (isSignedIn() && userIsHosterOf(request.resource.data.propertyId));
      allow update: if isAdmin() || (
        isSignedIn() &&
        userIsHosterOf(resource.data.propertyId) &&
        // Prevent moving bed to another property or room
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['propertyId', 'roomId'])
      );
      allow delete: if isAdmin() || (isSignedIn() && userIsHosterOf(resource.data.propertyId));
    }

    match /propertyStats/{propertyId} {
      allow read: if true;
      allow update: if isAdmin() || (isSignedIn() && userIsHosterOf(propertyId));
      allow create, delete: if isAdmin() || (isSignedIn() && userIsHosterOf(propertyId));
    }

    match /bed_reservations/{reservationId} {
      allow read: if isSignedIn() && (request.auth.uid == resource.data.userId || isAdmin() || userIsHosterOf(resource.data.propertyId));
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.userId;
      allow update, delete: if isAdmin();
    }

    match /inventory_events/{eventId} {
      allow read: if isAdmin() || (isSignedIn() && userIsHosterOf(resource.data.propertyId));
      allow create: if isSignedIn() && (isAdmin() || userIsHosterOf(request.resource.data.propertyId));
      allow update, delete: if isAdmin();
    }

    match /unlocked_data/{permissionId} {
      allow read: if isSignedIn() && (request.auth.uid == resource.data.user_id || isAdmin());
      allow write: if isAdmin(); // Only Admin (via Function/Service) can grant
    }

    // =========================================================
    // BOOKINGS
    // =========================================================

    match /bookings/{bookingId} {
      allow read: if isSignedIn() && (
        request.auth.uid == resource.data.user_id ||
        request.auth.uid == resource.data.userId ||
        request.auth.uid == resource.data.hoster_id ||
        request.auth.uid == resource.data.hosterId ||
        userIsHosterOf(resource.data.propertyId) ||
        userIsHosterOf(resource.data.property_id) ||
        isAdmin()
      );

      // Clients can no longer create or update bookings directly (must use API)
      allow create: if false;
      allow update: if false;
      allow delete: if isSuperAdmin();
    }

    // =========================================================
    // SUGGESTIONS, REPORTS, REVIEWS, WISHLISTS
    // =========================================================

    match /suggestions/{suggestionId} {
      allow create: if isSignedIn() && request.resource.data.user_id == request.auth.uid;
      allow get, list: if isAdmin() || (isSignedIn() && resource.data.user_id == request.auth.uid);
      allow update: if isAdmin() || (isSignedIn() && resource.data.user_id == request.auth.uid && resource.data.status == 'pending');
      allow delete: if isAdmin();
    }

    match /property_suggestions/{suggestionId} {
      allow create: if isSignedIn() && request.resource.data.suggester_id == request.auth.uid;
      allow read: if isAdmin() || (isSignedIn() && resource.data.suggester_id == request.auth.uid);
      allow update, delete: if isAdmin();
    }

    match /reports/{reportId} {
      allow create: if isSignedIn() && request.resource.data.user_id == request.auth.uid;
      allow read: if isAdmin() || (isSignedIn() && resource.data.user_id == request.auth.uid);
      allow update, delete: if isAdmin();
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if (isSignedIn() && request.auth.uid == resource.data.user_id) || isAdmin();
    }

    match /wishlists/{wishId} {
      allow read, write: if isSignedIn() && (request.auth.uid == (resource == null ? request.resource.data.user_id : resource.data.user_id));
    }

    // =========================================================
    // PAYMENTS & INVOICES (Read-Only for Users)
    // =========================================================

    match /payments/{paymentId} {
      allow read: if isSignedIn() && (
        request.auth.uid == resource.data.user_id ||
        request.auth.uid == resource.data.userId ||
        request.auth.uid == resource.data.hoster_id ||
        request.auth.uid == resource.data.hosterId ||
        userIsHosterOf(resource.data.propertyId) ||
        userIsHosterOf(resource.data.property_id) ||
        isAdmin()
      );
      allow write: if false;
    }

    match /invoices/{invoiceId} {
      allow read: if isSignedIn() && (
        isAdmin() ||
        (
          'booking_id' in resource.data &&
          (
            request.auth.uid == get(/databases/$(database)/documents/bookings/$(resource.data.booking_id)).data.user_id ||
            request.auth.uid == get(/databases/$(database)/documents/bookings/$(resource.data.booking_id)).data.userId
          )
        ) ||
        (
          'bookingId' in resource.data &&
          (
            request.auth.uid == get(/databases/$(database)/documents/bookings/$(resource.data.bookingId)).data.user_id ||
            request.auth.uid == get(/databases/$(database)/documents/bookings/$(resource.data.bookingId)).data.userId
          )
        )
      );
      allow write: if false;
    }

    // =========================================================
    // LEADS
    // =========================================================

    match /leads/{leadId} {
      allow read: if isSignedIn() && (
        request.auth.uid == resource.data.user_id ||
        request.auth.uid == resource.data.userId ||
        request.auth.uid == resource.data.hoster_id ||
        request.auth.uid == resource.data.hosterId ||
        userIsHosterOf(resource.data.propertyId) ||
        userIsHosterOf(resource.data.property_id) ||
        isAdmin()
      );
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (
        request.auth.uid == resource.data.user_id ||
        request.auth.uid == resource.data.userId ||
        request.auth.uid == resource.data.hoster_id ||
        request.auth.uid == resource.data.hosterId ||
        isAdmin()
      );
      allow delete: if isAdmin();
    }

    // =========================================================
    // NOTIFICATIONS
    // =========================================================

    match /notifications/{notifId} {
      allow read: if isSignedIn() && (
        request.auth.uid == resource.data.user_id ||
        request.auth.uid == resource.data.userId ||
        (isAdmin() && (resource.data.user_id == 'admin' || resource.data.userId == 'admin'))
      );
      allow update: if isSignedIn() && (
        request.auth.uid == resource.data.user_id ||
        request.auth.uid == resource.data.userId ||
        (isAdmin() && (resource.data.user_id == 'admin' || resource.data.userId == 'admin'))
      ) && (
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['is_read']) ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isRead'])
      );
      allow create: if isSignedIn() && (
        isAdmin() ||
        request.resource.data.user_id == 'admin' ||
        request.resource.data.userId == 'admin' ||
        request.resource.data.user_id == request.auth.uid ||
        request.resource.data.userId == request.auth.uid
      );
      allow delete: if isAdmin();
    }

    // =========================================================
    // SYSTEM & CONFIG (Mostly Read-Only)
    // =========================================================

    match /cities/{cityId} {
      allow read: if true;
      allow write: if isAdmin();
      match /areas/{areaId} {
        allow read: if true;
        allow write: if isAdmin();
      }
    }

    match /locations/{locationId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /config/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /settings/global {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /analytics/{docId} {
      allow read: if isAdmin() || isHoster();
      allow write: if false;
    }

    match /auditLogs/{logId} {
      allow read, create: if isAdmin();
      allow update, delete: if false;
    }

    match /activityLogs/{logId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /adminStats/{docId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /occupancyStats/{propertyId} {
      allow read: if isAdmin() || isHoster();
      allow write: if false;
    }

    match /revenueStats/{propertyId} {
      allow read: if isAdmin() || isHoster();
      allow write: if false;
    }

    match /complianceStats/{propertyId} {
      allow read: if isAdmin() || isHoster();
      allow write: if false;
    }

    match /complianceAlerts/{alertId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /propertyApprovals/{approvalId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    match /audit_logs/{logId} {
      allow read, create: if isAdmin();
      allow update, delete: if false;
    }

    match /activity_logs/{logId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /hoster_requests/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow create: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow update: if isAdmin();
    }

    match /admins/{adminId} {
      allow read: if isAdmin();
      allow write: if isSuperAdmin();
    }

    // =========================================================
    // STAFF & HOST MANAGEMENT
    // =========================================================

    match /hostAssignments/{assignmentId} {
      allow read: if isSignedIn() && (
        isAdmin() ||
        userIsHosterOf(resource.data.propertyId) ||
        request.auth.uid == resource.data.userId
      );
      allow create: if isSignedIn() && (
        isAdmin() ||
        userIsHosterOf(request.resource.data.propertyId)
      );
      allow update: if isSignedIn() && (
        isAdmin() ||
        userIsHosterOf(request.resource.data.propertyId)
      );
      allow delete: if isAdmin() || (isSignedIn() && userIsHosterOf(resource.data.propertyId));
    }

    match /hostInvitations/{invitationId} {
      allow read: if isSignedIn() && (
        isAdmin() ||
        userIsHosterOf(resource.data.propertyId) ||
        request.auth.token.email == resource.data.email
      );
      allow create: if isSignedIn() && (
        isAdmin() ||
        userIsHosterOf(request.resource.data.propertyId)
      );
      allow update: if isSignedIn() && (
        isAdmin() ||
        userIsHosterOf(request.resource.data.propertyId) ||
        request.auth.token.email == resource.data.email
      );
      allow delete: if isAdmin() || (isSignedIn() && userIsHosterOf(resource.data.propertyId));
    }

    match /hostActivities/{activityId} {
      allow read: if isSignedIn() && (
        isAdmin() ||
        userIsHosterOf(resource.data.propertyId)
      );
      allow create: if isSignedIn() && (
        isAdmin() ||
        userIsHosterOf(request.resource.data.propertyId) ||
        request.auth.uid == request.resource.data.hostId
      );
      allow update, delete: if isAdmin();
    }

    // =========================================================
    // MAINTENANCE TICKETS
    // =========================================================

    match /maintenance_tickets/{ticketId} {
      allow create: if isSignedIn() && request.resource.data.user_id == request.auth.uid;
      allow read: if isSignedIn() && (
        request.auth.uid == resource.data.user_id ||
        request.auth.uid == resource.data.hoster_id ||
        isAdmin()
      );
      allow update: if isSignedIn() && (
        request.auth.uid == resource.data.hoster_id ||
        isAdmin()
      );
      allow delete: if isAdmin();
    }

    // =========================================================
    // DISPUTES, ESCROW, & ADMIN ACTIONS
    // =========================================================

    match /disputes/{disputeId} {
      allow read, write: if isAdmin();
    }

    match /escrow/{escrowId} {
      allow read, write: if isAdmin();
    }

    match /admin_actions/{actionId} {
      allow read, write: if isAdmin();
    }

    match /systemHealth/{docId} {
      allow read: if isAdmin();
      allow write: if false;
    }
  }
}
