rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // Helper: Is the user signed in?
    function isSignedIn() {
      return request.auth != null;
    }

    // Helper: Is this the user's own folder?
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Profile Images: User can upload and update their own profile photo
    match /profile_images/{userId} {
      allow read: if true;
      allow write: if isOwner(userId.replace(".jpg", ""));
    }

    // Verification Documents: Secure folder for sensitive IDs
    match /verifications/{userId}/{allPaths=**} {
      // Only the user and admins should be able to read these
      allow read: if isOwner(userId);

      // Only the user can upload to their own folder
      allow write: if isOwner(userId);
    }

    // Property Images: Used for listing properties
    match /property_images/{allPaths=**} {
      allow read: if true;
      allow write: if isSignedIn();
    }
  }
}
