rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // Helper: Is the user signed in?
    function isSignedIn() {
      return request.auth != null;
    }

    // Helper: Is this the user's own folder?
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Helper: Is user an admin? (Cross-service check to Firestore)
    function isAdmin() {
      return isSignedIn() &&
        (firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role in ['admin', 'superadmin'] ||
         firestore.exists(/databases/(default)/documents/admins/$(request.auth.uid)));
    }

    // Profile Images: User can upload and update their own profile photo
    match /profile_images/{userId} {
      allow read: if true;
      allow write: if isSignedIn() && (request.auth.uid == userId || request.auth.uid == userId.replace(".jpg", "") || isAdmin());
    }

    // Verification Documents: Secure folder for sensitive IDs
    match /verifications/{userId}/{allPaths=**} {
      // Only the user and admins should be able to read these
      allow read: if isOwner(userId) || isAdmin();

      // Only the user and admins can upload to their own folder
      allow write: if isOwner(userId) || isAdmin();
    }

    // Property Images: Used for listing properties. Must be prefixed by user ID.
    match /property_images/{hosterId}/{allPaths=**} {
      allow read: if true;
      allow write: if isOwner(hosterId) || isAdmin();
    }
  }
}
